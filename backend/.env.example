PORT=5000
NODE_ENV=development

# Local PostgreSQL
PGHOST=localhost
PGUSER=postgres
PGPASSWORD=admin
PGDATABASE=tallervisitas_db
PGPORT=5432

# Railway/Render/PostgreSQL managed connection string. Leave empty locally if using PG* vars.
DATABASE_URL=
DB_SSL=

# Use a long random value in every deployed environment.
JWT_SECRET=replace-with-a-long-random-secret

# Comma-separated allowed origins in production.
# Railway domains are auto-allowed through RAILWAY_PUBLIC_DOMAIN.
# Example for custom domains:
# CORS_ORIGIN=https://app.example.com
CORS_ORIGIN=

# Local default: backend/uploads.
# Railway volume option: set UPLOAD_DIR to ${RAILWAY_VOLUME_MOUNT_PATH}/uploads
# Render default from render.yaml: /var/data/uploads
UPLOAD_DIR=
MAX_UPLOAD_MB=10
